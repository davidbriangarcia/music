<Window x:Class="MusicSyncApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        mc:Ignorable="d"
        Title="Music Sync App" Height="600" Width="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
                <TextBlock Text="Server IP:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="ServerIpInput" Width="100" Margin="0,0,10,0" Text="localhost"/>
                <Button Content="Connect" Click="Connect_Click" Width="70" Margin="0,0,20,0"/>
                
                <TextBlock Text="Room:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="RoomNameInput" Width="80" Margin="0,0,10,0" Text="room1"/>
                <Button Content="Join" Click="JoinRoom_Click" Width="50" Margin="0,0,10,0"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10,0,10,10">
                <TextBlock Text="Video ID:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="VideoIdInput" Width="120" Margin="0,0,10,0" Text="dQw4w9WgXcQ"/>
                <Button Content="Add Song" Click="AddSong_Click" Width="80" Margin="0,0,10,0"/>
                <Button Content="Play" Click="Play_Click" Width="60" Margin="0,0,5,0"/>
                <Button Content="Pause" Click="Pause_Click" Width="60"/>
            </StackPanel>
            
            <wv2:WebView2 x:Name="PlayerWebView" Source="about:blank" Margin="10"/>
        </DockPanel>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Playlist" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <ListBox x:Name="PlaylistListBox" Height="350" d:ItemsSource="{d:SampleData ItemCount=5}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" Margin="5">
                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Status}" FontSize="10" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            
            <UniformGrid Columns="2" Margin="0,10,0,0">
                <Button Content="Move Up" Click="MoveUp_Click" Margin="0,0,5,5"/>
                <Button Content="Move Down" Click="MoveDown_Click" Margin="5,0,0,5"/>
                <Button Content="Remove" Click="Remove_Click" Margin="0,5,5,0" Background="#FFFFE1E1"/>
                <Button Content="Play Selected" Click="PlaySelected_Click" Margin="5,5,0,0" Background="#FFE1FFE1"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
